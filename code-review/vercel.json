{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "includeFiles": ["next.config.js", "next.config.ts"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/socket_io(.*)",
      "dest": "/api/socket_io"
    },
    {
      "src": "/api/socket(.*)",
      "dest": "/api/socket"
    },
    {
      "src": "/classroom/(.*)",
      "dest": "/classroom"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}