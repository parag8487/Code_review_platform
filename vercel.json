{
  "version": 2,
  "builds": [
    {
      "src": "code-review/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/classroom/(.*)",
      "dest": "code-review/classroom/$1"
    },
    {
      "src": "/api/socket_io(.*)",
      "dest": "code-review/api/socket_io"
    },
    {
      "src": "/api/socket(.*)",
      "dest": "code-review/api/socket"
    },
    {
      "src": "/(.*)",
      "dest": "code-review/$1"
    }
  ]
}